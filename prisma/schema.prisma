// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// 1. Medicines: The core product definitions
model Medicine {
  id          String  @id @default(uuid())
  userId      String // Maps to Clerk User ID
  name        String
  barcode     String // The globally unique barcode for this medicine type
  description String?
  category    String? // e.g. "Antibiotics", "Painkillers"

  lowStockThreshold Int @default(10) // For alerts

  // Relations
  batches           Batch[]
  preferredVendorId String?
  preferredVendor   Vendor? @relation(fields: [preferredVendorId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  billItems BillItem[]

  @@unique([barcode, userId])
}

// 2. Batches: Specific stock entries (Expiry tracking happens here!)
model Batch {
  id         String   @id @default(uuid())
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id])

  batchNumber String // Printed on the box
  quantity    Int // Current stock for THIS batch

  costPrice    Float // Buying price per unit
  sellingPrice Float // Selling price per unit

  expiryDate DateTime

  isRecalled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serialNumbers SerialNumber[]
}

// 2b. Serial Numbers: Track individual medicine units for true Track-and-Trace
model SerialNumber {
  id          String    @id @default(uuid())
  code        String    @unique
  batchId     String
  status      String    @default("ACTIVE") // ACTIVE, DISPENSED, DESTROYED
  dispensedAt DateTime?

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

// 3. Vendors: Suppliers for re-ordering
model Vendor {
  id          String  @id @default(uuid())
  userId      String // Maps to Clerk User ID
  name        String
  contactName String?
  phone       String?
  email       String?

  medicines Medicine[]

  createdAt DateTime @default(now())
}

// 4. Billing
model Bill {
  id     String @id @default(uuid())
  userId String // Maps to Clerk User ID

  customerName  String?
  customerPhone String?

  items       BillItem[]
  totalAmount Float

  createdAt DateTime @default(now())
}

model BillItem {
  id     String @id @default(uuid())
  billId String
  bill   Bill   @relation(fields: [billId], references: [id])

  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id])

  quantity Int
  price    Float // Price at moment of sale
}

// 5. Pharmacy Settings
model PharmacySettings {
  id      String  @id @default(uuid())
  userId  String  @unique
  name    String  @default("My Pharmacy")
  phone   String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 6. Expiry Warning Settings (per-user thresholds)
model ExpirySettings {
  id                String @id @default(uuid())
  userId            String @unique

  earlyWarningDays  Int @default(90)  // Yellow: warn this many days before expiry
  urgentWarningDays Int @default(30)  // Orange: urgent warning
  criticalDays      Int @default(7)   // Red: critical / last chance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
